# Authentication Service - Environment Configuration Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ==================== DATABASE CONFIGURATION ====================
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_64_CHARS_MIN_ABCD1234567890!@#$%^&*()
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auth_service
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=40
SQLALCHEMY_POOL_PRE_PING=True

# ==================== JWT CONFIGURATION ====================
# Generate a strong SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_STRONG_64_CHAR_SECRET_KEY_ABCDabcd1234!@#$%^&*()_+-=[]{}|;:,.<>?
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# ==================== REDIS CONFIGURATION ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# ==================== SMTP CONFIGURATION ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM_ADDRESS=noreply@yourapp.com
EMAIL_FROM_NAME=Auth Service

# ==================== Outlook SMTP CONFIGURATION ====================
OUTLOOK_SMTP_HOST=smtp-mail.outlook.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_SMTP_USERNAME=your-address@outlook.com
OUTLOOK_SMTP_PASSWORD=your-app-password-or-account-password
OUTLOOK_EMAIL_FROM_ADDRESS=your-address@outlook.com
OUTLOOK_EMAIL_FROM_NAME=Your App Name  # optional, falls back to EMAIL_FROM_NAME

# ==================== APPLICATION URLs ====================
# MUST use HTTPS in production!
FRONTEND_URL=https://app.yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# ==================== SECURITY SETTINGS ====================
ENVIRONMENT=production
DEBUG=False
CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
REQUIRE_HTTPS=True

# ==================== RATE LIMITING ====================
RATE_LIMIT_LOGIN_ATTEMPTS=3
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_REGISTER_ATTEMPTS=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
RATE_LIMIT_PASSWORD_RESET_ATTEMPTS=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=3600
RATE_LIMIT_EMAIL_VERIFY_ATTEMPTS=10
RATE_LIMIT_EMAIL_VERIFY_WINDOW_SECONDS=600

# ==================== ACCOUNT SECURITY ====================
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_JSON_FORMAT=True

# ==================== REQUEST VALIDATION ====================
MAX_REQUEST_SIZE_MB=10
